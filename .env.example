# Discord Bot Configuration
DISCORD_TOKEN="your_token_here"
# Comma-separated list of allowed Guild IDs (numeric)
ALLOWED_GUILDS=""
# Comma-separated list of allowed User IDs (numeric)
ALLOWED_USERS=""
# The internal URL for the bot to reach the Flask API (use 127.0.0.1 if on same machine)
PDFSEARCH_BASE="http://localhost:5001"
# Comma-separated list of folder names the bot is allowed to search (leave empty for no restriction)
ALLOWED_FOLDERS="Star Wars,ASOIAF,Warhammer"